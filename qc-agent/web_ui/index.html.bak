<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QC-AGENT | The Synthetic Architect</title>
    <!-- Tailwind for utilities, but main design is in index.css -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="index.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="bg-gray-950 text-gray-200">
    <div class="app-container">
        <!-- TOP BAR -->
        <header class="top-bar">
            <div class="flex items-center gap-4">
                <div class="bg-primary px-3 py-1 rounded text-surface font-bold text-xs headline uppercase tracking-tighter">
                    SAOLA QC-AGENT v2
                </div>
                <div class="flex items-center gap-2 text-xs text-gray-500 font-medium">
                    <span class="status-dot live"></span>
                    VECTOR DB: <span id="db-status-text" class="text-gray-300">SEARCHING...</span>
                </div>
            </div>
            
            <div class="flex items-center gap-8">
                <!-- Agent Status Bar (Last 10 executions) -->
                <div class="flex flex-col items-end gap-1">
                    <span class="text-[9px] text-gray-500 uppercase font-bold tracking-widest">Global Fleet Status</span>
                    <div id="fleet-status-bar" class="agent-status-bar">
                        <!-- Filled by JS -->
                        <div class="status-square status-pass"></div>
                        <div class="status-square status-pass"></div>
                        <div class="status-square status-fail"></div>
                        <div class="status-square status-pass"></div>
                        <div class="status-square status-pass"></div>
                    </div>
                </div>
                
                <div class="flex items-center gap-4 border-l border-gray-800 pl-4 h-8">
                    <i class="fa-solid fa-gear text-gray-500 hover:text-white cursor-pointer transition-colors"></i>
                    <i class="fa-solid fa-bell text-gray-500 hover:text-white cursor-pointer transition-colors"></i>
                    <div class="w-8 h-8 rounded-full bg-surface-container-highest border border-outline-variant flex items-center justify-center">
                        <i class="fa-solid fa-user text-[10px] text-primary"></i>
                    </div>
                </div>
            </div>
        </header>

        <!-- SIDEBAR (Controls) -->
        <aside class="sidebar border-r border-outline-variant">
            <div class="flex flex-col gap-1">
                <h3 class="text-[10px] text-primary uppercase font-bold tracking-widest opacity-60">System Controls</h3>
                <div class="flex flex-col gap-2 mt-4">
                    <button class="tab-button active flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all" data-tab="add-data">
                        <i class="fa-solid fa-database w-5"></i> Thêm Dữ Liệu
                    </button>
                    <button class="tab-button flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all text-gray-500 hover:text-white" data-tab="fast-track">
                        <i class="fa-solid fa-bolt-lightning w-5"></i> Fast Track MVP
                    </button>
                    <button class="tab-button flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all text-gray-500 hover:text-white" data-tab="playground">
                        <i class="fa-solid fa-search w-5"></i> Playground (RAG)
                    </button>
                </div>
            </div>
            
            <div class="mt-auto flex flex-col gap-6 pt-6 border-t border-outline-variant">
                <!-- Model Selection -->
                <div class="flex flex-col gap-3">
                    <label class="text-[10px] text-gray-500 uppercase font-bold tracking-widest">AI Engine</label>
                    <div id="default-models-info" class="flex flex-col gap-2">
                        <div class="bg-surface-container-lowest p-3 rounded-lg border border-outline-variant">
                            <div class="text-[9px] text-gray-500 uppercase mb-1">Planner</div>
                            <div id="planner-default-name" class="text-xs text-primary font-bold">Qwen3-32B</div>
                        </div>
                        <div class="bg-surface-container-lowest p-3 rounded-lg border border-outline-variant">
                            <div class="text-[9px] text-gray-500 uppercase mb-1">SDET Tester</div>
                            <div id="tester-default-name" class="text-xs text-primary font-bold">Qwen3-32B</div>
                        </div>
                    </div>
                </div>
                
                <!-- System Info Panel -->
                <div id="system-info-panel" class="bg-surface-container-lowest p-4 rounded-lg border border-outline-variant border-dashed">
                    <div class="text-[10px] text-gray-500 uppercase font-bold mb-3">Live Metrics</div>
                    <div id="db-info-panel" class="flex flex-col gap-2 text-[11px]">
                        <!-- JS filled -->
                    </div>
                </div>
            </div>
        </aside>

        <!-- MAIN CONTENT AREA -->
        <main class="main-content">
            <!-- Left: Active Workspace -->
            <div class="content-scroll">
                
                <!-- Tab: Add Data -->
                <div id="add-data" class="tab-content active flex-col gap-6">
                    <div class="flex items-end justify-between">
                        <div>
                            <h2 class="text-2xl font-bold headline text-white">Memory Ingestion</h2>
                            <p class="text-sm text-gray-500">Nạp tập hợp tri thức hoặc tài liệu spec vào Vector DB.</p>
                        </div>
                        <div class="flex gap-1 p-1 bg-surface-container-low rounded-lg border border-outline-variant">
                            <button class="data-type-tab active px-4 py-1.5 rounded-md text-[11px] font-bold uppercase tracking-tight transition-all" data-type="text">Text</button>
                            <button class="data-type-tab px-4 py-1.5 rounded-md text-[11px] font-bold uppercase tracking-tight text-gray-500 hover:text-white transition-all" data-type="url">URL</button>
                            <button class="data-type-tab px-4 py-1.5 rounded-md text-[11px] font-bold uppercase tracking-tight text-gray-500 hover:text-white transition-all" data-type="file">File</button>
                        </div>
                    </div>
                    
                    <form id="memory-form" class="flex flex-col gap-4">
                        <div id="text-input-container" class="relative">
                            <textarea id="text-input" name="text" rows="18"
                                class="w-full bg-surface-container-low border border-outline-variant text-gray-200 rounded-xl p-6 focus:ring-1 focus:ring-primary focus:border-primary outline-none mono text-sm transition-all"
                                placeholder="[INPUT]: Paste technical documentation, requirements, or code snippets here..."></textarea>
                        </div>
                        <div id="url-input-container" class="hidden">
                            <input type="url" id="url-input" name="url"
                                class="w-full bg-surface-container-low border border-outline-variant text-gray-200 rounded-xl p-6 focus:ring-1 focus:ring-primary focus:border-primary outline-none text-sm transition-all"
                                placeholder="https://docs.api.example.com/spec">
                        </div>
                        <div id="file-input-container" class="hidden p-12 bg-surface-container-low border-2 border-dashed border-outline-variant rounded-xl flex flex-col items-center justify-center gap-4">
                            <i class="fa-solid fa-cloud-arrow-up text-4xl text-gray-600"></i>
                            <div class="text-center">
                                <p class="text-sm font-semibold text-gray-300">Click to upload or drag and drop</p>
                                <p class="text-[10px] text-gray-500 mt-1 uppercase tracking-widest">PDF, DOCX, XLSX, TXT, MD</p>
                            </div>
                            <input type="file" id="file-input" name="file" class="absolute inset-0 opacity-0 cursor-pointer">
                        </div>
                        
                        <div class="flex justify-end pt-2">
                            <button type="submit" class="btn-primary">
                                <i class="fa-solid fa-plus"></i> INITIALIZE INGESTION
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Tab: Fast Track -->
                <div id="fast-track" class="tab-content hidden flex-col gap-6">
                    <div class="flex items-end justify-between">
                        <div>
                            <h2 class="text-2xl font-bold headline text-white font-black italic">FAST TRACK <span class="text-primary tracking-tighter">SDET</span></h2>
                            <p class="text-sm text-gray-500">Quy trình tự động: Planning -> Scripting -> Automation Code.</p>
                        </div>
                        <div class="flex items-center gap-4 bg-surface-container-low p-2 rounded-lg border border-outline-variant">
                             <div class="flex items-center gap-2">
                                <span class="text-[9px] text-gray-500 uppercase font-bold">Auto-Push Jira</span>
                                <label class="relative inline-flex items-center cursor-pointer scale-90">
                                    <input type="checkbox" id="toggle-auto-push" class="sr-only peer">
                                    <div class="w-8 h-4 bg-gray-600 rounded-full peer peer-checked:bg-primary-container after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:after:translate-x-4"></div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1">
                            <label class="text-[9px] text-gray-500 uppercase font-bold tracking-widest pl-1">Jira Test Cycle</label>
                            <div class="flex gap-2">
                                <input type="text" id="cycle-id-input" value="NCPP-C302" class="flex-grow bg-surface-container-low border border-outline-variant rounded-lg p-3 text-sm focus:border-primary outline-none transition-all">
                                <button onclick="extractCycle()" id="extract-cycle-btn" class="bg-secondary-container px-4 rounded-lg text-xs font-bold hover:bg-gray-700 transition-colors">
                                    <i class="fa-solid fa-magnifying-glass"></i> SCAN
                                </button>
                            </div>
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-[9px] text-gray-500 uppercase font-bold tracking-widest pl-1">Project Identifier</label>
                            <input type="text" id="project-key-input" value="NCPP" class="bg-surface-container-low border border-outline-variant rounded-lg p-3 text-sm focus:border-primary outline-none transition-all">
                        </div>
                    </div>

                    <div id="cycle-extraction-view" class="hidden p-4 bg-surface-container-lowest rounded-xl border border-outline-variant">
                        <div class="flex justify-between items-center mb-4">
                            <span id="cycle-summary-text" class="text-[10px] text-primary font-bold uppercase tracking-widest">Found 0 cases</span>
                            <button onclick="syncCycleToVector()" id="sync-vector-btn" class="text-[10px] text-white bg-purple-900 px-3 py-1 rounded font-bold hover:bg-purple-800 transition-all">
                                SYNC TO MEMORY
                            </button>
                        </div>
                        <div id="cycle-cases-list" class="flex flex-col gap-1 max-h-48 overflow-y-auto pr-2"></div>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label class="text-[9px] text-gray-500 uppercase font-bold tracking-widest pl-1">Context / Instruction</label>
                        <textarea id="instruction-input" rows="6"
                            class="w-full bg-surface-container-low border border-outline-variant text-gray-200 rounded-xl p-6 focus:ring-1 focus:ring-primary focus:border-primary outline-none text-sm transition-all"
                            placeholder="Describe what you want to test... (e.g., 'Test the login flow with valid/invalid credentials')"></textarea>
                    </div>

                    <div class="flex justify-between items-center py-2">
                         <button id="clear-db-button" class="text-[10px] text-red-500/60 hover:text-red-400 font-bold uppercase tracking-tighter transition-all">
                            Purge Vector Store
                        </button>
                        <button type="submit" id="ft-submit-btn" class="btn-primary liquid-neon border-none text-surface">
                            <i class="fa-solid fa-play"></i> EXECUTE NEURAL PIPELINE
                        </button>
                    </div>

                    <!-- Fast Track Results View -->
                    <div id="fast-track-results-container" class="mt-4 flex flex-col gap-4">
                        <div id="fast-track-results" class="flex flex-col gap-4">
                            <!-- JS filled -->
                        </div>
                    </div>
                </div>

                <!-- Tab: Playground -->
                <div id="playground" class="tab-content hidden flex-col gap-6">
                    <div>
                        <h2 class="text-2xl font-bold headline text-white">Semantic Playground</h2>
                        <p class="text-sm text-gray-500">Tra cứu trực tiếp nội dung từ bộ nhớ Vector (RAG Debugging).</p>
                    </div>
                    
                    <form id="retrieval-form" class="flex flex-col gap-4">
                        <div class="flex flex-col gap-2">
                            <textarea id="query-input" rows="8"
                                class="w-full bg-surface-container-low border border-outline-variant text-gray-200 rounded-xl p-6 focus:ring-1 focus:ring-primary focus:border-primary outline-none text-sm transition-all"
                                placeholder="[QUERY]: Search knowledge base..."></textarea>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="text-[10px] text-gray-500 uppercase font-bold">Density (Top K):</span>
                                <input type="number" id="top-k-input" value="3" min="1" class="w-20 bg-surface-container-low border border-outline-variant p-2 rounded-lg text-xs outline-none">
                            </div>
                            <button type="submit" class="btn-primary bg-tertiary-container text-on-tertiary-container shadow-none">
                                <i class="fa-solid fa-magnifying-glass"></i> RUN RETRIEVAL
                            </button>
                        </div>
                    </form>
                    <div id="retrieval-results" class="flex flex-col gap-4"></div>
                </div>
            </div>

            <!-- Right: Live Logs / Fleet Events -->
            <div class="log-panel">
                <div class="p-4 border-b border-outline-variant flex justify-between items-center bg-surface-container-high">
                    <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Fleet Telemetry</span>
                    <button onclick="loadMemoryFiles()" class="text-[9px] text-primary hover:underline">REFRESH</button>
                </div>
                <!-- Memory Files Area -->
                <div class="p-4 flex flex-col gap-3">
                    <div class="flex justify-between items-center">
                        <span class="text-[9px] text-gray-600 uppercase font-bold">Stored Archives</span>
                    </div>
                    <div id="memory-files-list" class="flex flex-col gap-2 overflow-y-auto max-h-[200px] pr-2">
                        <!-- JS filled -->
                    </div>
                </div>
                
                <div class="flex-grow flex flex-col overflow-hidden border-t border-outline-variant">
                    <div class="p-4 bg-surface-container-lowest border-b border-outline-variant text-[10px] text-gray-500 font-bold uppercase tracking-widest flex items-center gap-2">
                        <i class="fa-solid fa-terminal text-primary"></i> Live Process Stream
                    </div>
                    <div id="live-log-stream" class="flex-grow overflow-y-auto p-4 mono text-[10px] leading-relaxed text-gray-400 bg-[#0e0e0e]">
                        <div class="mb-1 opacity-40">[SYSTEM]: MONITORING AGENT FLEET...</div>
                        <div class="mb-1 opacity-40">[STATUS]: VECTOR DB CONNECTED...</div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- NOTIFICATION -->
    <div id="response-message" class="fixed bottom-6 right-6 p-4 rounded-xl glass border border-primary/20 text-xs font-semibold shadow-2xl z-50 transition-all hidden animate-bounce"></div>

    <script>
        const API_BASE_URL = 'http://127.0.0.1:5001';

        // --- DOM Elements ---
        const mainTabs = document.querySelectorAll('.tab-button');
        const tabContents = document.querySelectorAll('.tab-content');
        const dataTypeTabs = document.querySelectorAll('.data-type-tab');
        
        const memoryForm = document.getElementById('memory-form');
        const retrievalForm = document.getElementById('retrieval-form');
        const fastTrackForm = document.getElementById('Fast Track (the form inside fast-track tab)'); // Wait, the ID in my template changed or remained?
        const ftForm = document.getElementById('ft-submit-btn').closest('form'); 

        const logsDiv = document.getElementById('live-log-stream');
        const responseMessage = document.getElementById('response-message');
        const fleetStatusBar = document.getElementById('fleet-status-bar');

        let currentDataType = 'text';

        // Custom logging to the UI stream
        function console_log_ui(message, type = 'SYSTEM') {
            const time = new Date().toLocaleTimeString();
            const div = document.createElement('div');
            div.className = 'mb-1';
            let color = 'text-gray-500';
            if (type === 'ERROR') color = 'text-red-500';
            if (type === 'SUCCESS') color = 'text-green-400';
            if (type === 'AI') color = 'text-primary';
            
            div.innerHTML = `<span class="opacity-30">[${time}]</span> <span class="${color} font-bold">[${type}]:</span> ${message}`;
            logsDiv.appendChild(div);
            logsDiv.scrollTop = logsDiv.scrollHeight;
        }

        const showMessage = (message, isError = false) => {
            responseMessage.textContent = message;
            responseMessage.classList.remove('hidden');
            responseMessage.style.display = 'block';
            if (isError) {
                responseMessage.className = "fixed bottom-6 right-6 p-4 rounded-xl glass border border-red-500/30 text-red-300 text-xs font-semibold shadow-2xl z-50 animate-pulse";
                console_log_ui(message, 'ERROR');
            } else {
                responseMessage.className = "fixed bottom-6 right-6 p-4 rounded-xl glass border border-primary/30 text-primary text-xs font-semibold shadow-2xl z-50";
                console_log_ui(message, 'SUCCESS');
            }
            setTimeout(() => {
                responseMessage.classList.add('hidden');
            }, 5000);
        };

        const fetchSystemInfo = async () => {
            try {
                const response = await fetch(`${API_BASE_URL}/info`);
                if (!response.ok) throw new Error('Backend Disconnected');
                const data = await response.json();
                
                document.getElementById('db-status-text').innerText = 'LIVE';
                document.getElementById('db-status-text').className = 'text-primary font-bold';

                document.getElementById('db-info-panel').innerHTML = `
                    <div class="flex justify-between"><span class="text-gray-500 uppercase">Provider</span><span class="text-white">${data.provider}</span></div>
                    <div class="flex justify-between"><span class="text-gray-500 uppercase">Local Model</span><span class="text-white">${data.embedding_model}</span></div>
                    <div class="flex justify-between items-center mt-2 border-t border-outline-variant pt-2 font-bold">
                        <span class="text-gray-500 uppercase">Vector Chunks</span>
                        <span class="text-primary text-[14px]">${data.item_count}</span>
                    </div>
                `;
            } catch (error) {
                document.getElementById('db-status-text').innerText = 'OFFLINE';
                document.getElementById('db-status-text').className = 'text-red-500 font-bold';
            }
        };

        const fetchExecutionHistory = async () => {
            try {
                const response = await fetch(`${API_BASE_URL}/execution-history`);
                const data = await response.json();
                fleetStatusBar.innerHTML = '';
                data.forEach(run => {
                    const sq = document.createElement('div');
                    sq.className = `status-square ${run.status === 'PASS' ? 'status-pass' : 'status-fail'}`;
                    sq.title = `${run.id} - ${run.timestamp}`;
                    fleetStatusBar.appendChild(sq);
                });
            } catch (e) {}
        };

        // --- Event Listeners ---
        mainTabs.forEach(tab => {
            tab.addEventListener('click', () => {
                mainTabs.forEach(t => {
                    t.classList.remove('active', 'text-white');
                    t.classList.add('text-gray-500');
                });
                tab.classList.add('active', 'text-white');
                tab.classList.remove('text-gray-500');
                
                const tabId = tab.dataset.tab;
                document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
                document.getElementById(tabId).classList.remove('hidden');
            });
        });

        dataTypeTabs.forEach(tab => {
            tab.addEventListener('click', (e) => {
                e.preventDefault();
                dataTypeTabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                currentDataType = tab.dataset.type;
                
                document.getElementById('text-input-container').classList.add('hidden');
                document.getElementById('url-input-container').classList.add('hidden');
                document.getElementById('file-input-container').classList.add('hidden');
                
                document.getElementById(`${currentDataType}-input-container`).classList.remove('hidden');
            });
        });

        memoryForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            console_log_ui(`Initializing ingestion via [${currentDataType.toUpperCase()}]...`, 'SYSTEM');
            const button = e.target.querySelector('button[type="submit"]');
            button.disabled = true;
            button.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> SYNCING...';

            let endpoint = '';
            let payload = {};
            let headers = { 'Content-Type': 'application/json' };

            try {
                if (currentDataType === 'text') {
                    endpoint = '/add-text';
                    payload = JSON.stringify({ text: document.getElementById('text-input').value });
                } else if (currentDataType === 'url') {
                    endpoint = '/add-url';
                    payload = JSON.stringify({ url: document.getElementById('url-input').value });
                } else if (currentDataType === 'file') {
                    endpoint = '/add-file';
                    const fileInput = document.getElementById('file-input');
                    if (!fileInput.files.length) throw new Error("File input is empty.");
                    const formData = new FormData();
                    formData.append('file', fileInput.files[0]);
                    payload = formData;
                    headers = {};
                }

                const response = await fetch(API_BASE_URL + endpoint, { method: 'POST', headers, body: payload });
                const result = await response.json();
                if (!response.ok) throw new Error(result.error);
                showMessage(result.message);
                memoryForm.reset();
                fetchSystemInfo();
                loadMemoryFiles();
            } catch (error) {
                showMessage(error.message, true);
            } finally {
                button.disabled = false;
                button.innerHTML = '<i class="fa-solid fa-plus"></i> INITIALIZE INGESTION';
            }
        });

        ftForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const resultsDiv = document.getElementById('fast-track-results');
            resultsDiv.innerHTML = `
                <div class="glass p-6 rounded-xl border border-primary/20 flex flex-col items-center gap-4">
                    <div class="loader-linear w-full h-1 bg-gray-900 rounded-full overflow-hidden">
                        <div class="h-full bg-primary animate-progress-ind"></div>
                    </div>
                    <div class="text-[10px] mono text-primary uppercase font-bold tracking-widest">[SYSTEM]: NEURAL PIPELINE INITIALIZING...</div>
                </div>
            `;
            console_log_ui("Starting Fast Track cycle...", "AI");

            const submitBtn = document.getElementById('ft-submit-btn');
            submitBtn.disabled = true;

            try {
                const instruction = document.getElementById('instruction-input').value;
                const cycle_id = document.getElementById('cycle-id-input').value;
                const project_key = document.getElementById('project-key-input').value;

                const response = await fetch(`${API_BASE_URL}/fast-track`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ instruction, cycle_id, project_key })
                });

                const result = await response.json();
                if (!response.ok) throw new Error(result.error);

                resultsDiv.innerHTML = ''; // Clear loading
                
                // Construct result blocks
                resultsDiv.innerHTML += `
                    <div class="p-4 bg-surface-container-high rounded-xl border border-outline-variant flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <span class="chip ${result.overall_status === 'PASS' ? 'chip-done' : 'chip-failed'}">${result.overall_status}</span>
                            <span class="text-xs font-bold headline">CLEAN CYCLE RESULT</span>
                        </div>
                        ${result.jira ? `<a href="${result.jira}" target="_blank" class="text-[10px] text-primary underline font-bold uppercase tracking-widest">Jira Archive</a>` : ''}
                    </div>
                `;

                result.results.forEach((r, idx) => {
                    const resultBlock = document.createElement('div');
                    resultBlock.className = 'card animate-fade-in';
                    resultBlock.innerHTML = `
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex flex-col gap-1">
                                <div class="flex items-center gap-2">
                                    <span class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">${r.tester}</span>
                                    <span class="text-[10px] text-primary font-mono">${r.jira_test_case_id || 'LOCAL_RUN'}</span>
                                </div>
                                <h4 class="text-sm font-bold text-white">${r.target}</h4>
                            </div>
                            <div class="flex items-center gap-2">
                                <button onclick="pushToJira(${idx}, ${JSON.stringify(r).replace(/"/g, '&quot;')})" class="text-[9px] bg-secondary-container px-2 py-1 rounded font-bold hover:text-white transition-all">APPROVE & PUSH</button>
                                <span class="chip ${r.status === 'PASS' ? 'chip-done' : 'chip-failed'}">${r.status}</span>
                            </div>
                        </div>
                        <div class="flex gap-2 mb-4 bg-surface-container-lowest p-1 rounded-md">
                            <button onclick="switchTaskTab(${idx}, 'script')" id="tab-btn-script-${idx}" class="py-1.5 px-3 text-[9px] font-bold uppercase rounded-md transition-all bg-surface-container-highest text-white">Spec</button>
                            <button onclick="switchTaskTab(${idx}, 'code')" id="tab-btn-code-${idx}" class="py-1.5 px-3 text-[9px] font-bold uppercase border border-transparent rounded-md text-gray-500 hover:text-gray-300">Playwright</button>
                        </div>
                        <div id="tab-content-script-${idx}" class="mono text-[11px]">
                            <textarea id="evidence-editor-${idx}" class="w-full bg-surface-container-lowest border border-outline-variant p-4 h-64 outline-none rounded-lg text-gray-400 focus:border-primary/40">${r.result.evidence}</textarea>
                        </div>
                        <div id="tab-content-code-${idx}" class="hidden mono text-[11px]">
                            <textarea id="code-editor-${idx}" class="w-full bg-[#000] border border-outline-variant p-4 h-64 outline-none rounded-lg text-green-400 font-medium focus:border-primary/40">${r.result.automation_code || '# Code snippet not generated'}</textarea>
                             <div class="flex justify-end gap-2 mt-2">
                                <button onclick="executeTaskCode(${idx})" class="text-[9px] text-green-400 uppercase font-black tracking-widest hover:underline">RUN_SANDBOX_V1</button>
                            </div>
                        </div>
                    `;
                    resultsDiv.appendChild(resultBlock);
                });
                
                fetchExecutionHistory();
            } catch (e) {
                showMessage(e.message, true);
            } finally {
                submitBtn.disabled = false;
            }
        });

        // Add stubs for new layout functions or refactor old ones
        async function loadMemoryFiles() {
            const listDiv = document.getElementById('memory-files-list');
            try {
                const response = await fetch(`${API_BASE_URL}/list-uploads`);
                const data = await response.json();
                listDiv.innerHTML = '';
                data.files.forEach(f => {
                    const item = document.createElement('div');
                    item.className = 'bg-surface-container-lowest p-2 rounded border border-outline-variant flex justify-between items-center group cursor-pointer hover:border-primary/30';
                    item.innerHTML = `<span class="text-[10px] text-gray-400 group-hover:text-primary transition-colors">${f}</span><i class="fa-solid fa-chevron-right text-[8px] opacity-20 group-hover:opacity-100"></i>`;
                    item.onclick = () => console_log_ui(`Viewing archive: ${f}`, 'SYSTEM');
                    listDiv.appendChild(item);
                });
            } catch (e) {}
        }

        function switchTaskTab(idx, tab) {
            document.getElementById(`tab-content-script-${idx}`).classList.add('hidden');
            document.getElementById(`tab-content-code-${idx}`).classList.add('hidden');
            document.getElementById(`tab-btn-script-${idx}`).className = "py-1.5 px-3 text-[9px] font-bold uppercase rounded-md text-gray-500 hover:text-gray-300";
            document.getElementById(`tab-btn-code-${idx}`).className = "py-1.5 px-3 text-[9px] font-bold uppercase rounded-md text-gray-500 hover:text-gray-300";

            document.getElementById(`tab-content-${tab}-${idx}`).classList.remove('hidden');
            document.getElementById(`tab-btn-${tab}-${idx}`).className = "py-1.5 px-3 text-[9px] font-bold uppercase border border-transparent rounded-md bg-surface-container-highest text-white";
        }

        // Initialize
        fetchSystemInfo();
        fetchExecutionHistory();
        loadMemoryFiles();
        setInterval(fetchExecutionHistory, 30000);
        
        console_log_ui("Fleet status initialized.", "SYSTEM");
        console_log_ui("Synthetic Architect UI loaded successfully.", "SYSTEM");

    </script>

    <style>
        @keyframes progress-ind {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        .animate-progress-ind {
            animation: progress-ind 1.5s infinite linear;
            width: 50%;
        }
        .animate-fade-in {
            animation: fadeIn 0.4s ease-out forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</body>

</html>